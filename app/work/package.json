{
  "name": "willow-work",
  "version": "1.0.0",
  "description": "pi",
  "keywords": [],
  "license": "MIT",
  "main": ".vite/build/main.js",
  "scripts": {
    "dev": "electron-forge start",
    "predev": "pnpm run rebuild:native",
    "package": "electron-forge package",
    "prepackage": "pnpm run rebuild:native",
    "package:mac": "electron-forge package --platform=darwin",
    "prepackage:mac": "pnpm run rebuild:native",
    "make": "electron-forge make",
    "premake": "pnpm run rebuild:native",
    "make:mac": "electron-forge make --platform=darwin",
    "premake:mac": "pnpm run rebuild:native",
    "make:mac:arm64": "electron-forge make --platform=darwin --arch=arm64",
    "premake:mac:arm64": "pnpm run rebuild:native",
    "make:mac:x64": "electron-forge make --platform=darwin --arch=x64",
    "premake:mac:x64": "pnpm run rebuild:native",
    "publish": "electron-forge publish",
    "lint": "oxlint src/",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "rebuild:native": "env HOME=$PWD/../.. electron-rebuild --force --which-module better-sqlite3 --module-dir ../.. --dist-url=https://npmmirror.com/mirrors/electron",
    "postinstall": "pnpm run rebuild:native"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.73.1",
    "@mariozechner/pi-ai": "^0.73.1",
    "@opencode-ai/sdk": "^1.1.53",
    "@tiptap/core": "^3.22.3",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@tiptap/vue-3": "^3.22.3",
    "@vueuse/core": "^12.8.2",
    "@willow/core": "workspace:*",
    "@willow/editor-md": "workspace:*",
    "@willow/sender": "workspace:*",
    "@willow/shadcn": "workspace:*",
    "@willow/ui": "workspace:*",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^11.0.2",
    "lucide-vue-next": "^0.473.0",
    "node-cron": "^4.2.1",
    "pinia": "^3.0.4",
    "reka-ui": "^2.8.0",
    "rxjs": "^7.8.2",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "vue-router": "4",
    "vue-sonner": "^2.0.9"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.6.0",
    "@electron-forge/maker-deb": "^7.6.0",
    "@electron-forge/maker-dmg": "^7.6.0",
    "@electron-forge/maker-rpm": "^7.6.0",
    "@electron-forge/maker-squirrel": "^7.6.0",
    "@electron-forge/maker-zip": "^7.6.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.6.0",
    "@electron-forge/plugin-fuses": "^7.6.0",
    "@electron-forge/plugin-vite": "^7.6.0",
    "@electron/fuses": "^1.8.0",
    "@rollup/plugin-swc": "^0.4.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@typescript/native-preview": "catalog:",
    "@vitejs/plugin-vue": "^6.0.5",
    "@willow/poetry": "workspace:*",
    "drizzle-kit": "^0.31.9",
    "electron": "catalog:",
    "esbuild-plugin-tsc": "^0.4.0",
    "inversify": "catalog:",
    "reflect-metadata": "catalog:",
    "shadcn-vue": "^2.4.3",
    "ts-node": "^10.0.0",
    "vite": "^8.0.0",
    "vue": "^3.5.31"
  },
  "productName": "Willow Work"
}
