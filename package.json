{
  "name": "willow",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm --filter ./app/work run dev",
    "dev:ui": "pnpm --filter ./app/ui-playground run dev",
    "dev:p": "pnpm --filter ./packages/poetry run dev",
    "lint": "oxlint app/ packages/",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "prepare": "husky"
  },
  "devDependencies": {
    "@typescript/native-preview": "catalog:",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "shadcn-vue": "^2.6.2"
  },
  "lint-staged": {
    "*.{ts,tsx,vue}": [
      "oxlint --fix",
      "oxfmt"
    ],
    "*.{css,json}": [
      "oxfmt"
    ]
  },
  "packageManager": "pnpm@9.15.4+sha512.b2dc20e2fc72b3e18848459b37359a32064663e5627a51e4c74b2c29dd8e8e0491483c3abb40789cfd578bf362fb6ba8261b05f0387d76792ed6e23ea3b1b6a0"
}
